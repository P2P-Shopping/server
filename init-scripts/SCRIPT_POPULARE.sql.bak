UPDATE raw_user_pings
SET store_id = 'a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d'
WHERE ping_id IN (
    SELECT ping_id FROM raw_user_pings
    WHERE store_id = '8f3e1a2b-c4d5-6e7f-8a9b-0c1d2e3f4a5b'
    LIMIT 1500
    );

